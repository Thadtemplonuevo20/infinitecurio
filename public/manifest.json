{
  "manifest_version": 3,
  "name": "Infinite Curio",
  "version": "1.0.0",
  "description": "Premium futuristic collectibles marketplace assistant.",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
